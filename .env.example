# ======================================================
# Servio — Root Environment Variables
# ======================================================
# Copy this file to .env and fill in your actual values.
# This file is used by docker-compose.yml and docker-compose.prod.yml.
# NEVER commit the .env file to version control.
# ======================================================

# ---------- Supabase Database ----------
DB_HOST=aws-0-<your-region>.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.<your-project-ref>
DB_PASSWORD=your-supabase-db-password
DB_NAME=postgres

# ---------- Supabase Auth ----------
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------- JWT (Backend) ----------
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRATION=604800000

# ---------- CORS / Frontend URLs ----------
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
FRONTEND_URL=http://localhost:5173,http://localhost:3000,http://localhost,http://localhost:80

# ---------- Vite (Frontend Build Args) ----------
# In local dev with docker-compose, use the nginx reverse proxy path:
VITE_API_URL=/api
# For S3/CloudFront deployment, set to the EC2 backend URL:
# VITE_API_URL=http://<your-ec2-ip>:3001/api

# ---------- PayHere Payment Gateway ----------
PAYHERE_MERCHANT_ID=1219999
PAYHERE_MERCHANT_SECRET=your-merchant-secret-here
PAYHERE_SANDBOX=true

# ---------- AWS (CI/CD — set these in GitHub Secrets, not here) ----------
# AWS_ACCOUNT_ID=123456789012
# AWS_REGION=ap-south-1
